{
  "name": "triviafutbol-backend",
  "version": "1.0.0",
  "description": "Backend de TriviaFutbol",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit",
    "test:int": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "migrate": "node-pg-migrate up --migrations-dir src/db/migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir src/db/migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir src/db/migrations",
    "seed": "node src/db/seeds/run.js",
    "lint": "eslint src/"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "node-pg-migrate": {
    "migrationsDir": "src/db/migrations",
    "databaseUrlEnvVar": "DATABASE_URL",
    "dir": "src/db/migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
